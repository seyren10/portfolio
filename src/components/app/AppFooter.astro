---
import {
  GithubIcon,
  Linkedin02Icon,
  Mail01Icon,
} from "@hugeicons/core-free-icons"
import { HugeiconsIcon } from "@hugeicons/react"
---

<footer class="border-t bg-slate-50/50 dark:bg-slate-950/50">
  <div class="container mx-auto max-w-4xl px-4 py-16">
    <div class="grid gap-12 md:grid-cols-3">
      <!-- Left Column -->
      <div>
        <h3 class="text-xl font-bold text-slate-900 dark:text-white">
          Roy Victor Gagarin
        </h3>
        <p class="mt-2 text-sm text-slate-600 dark:text-slate-400">
          Full Stack Developer
        </p>
        <p class="mt-4 text-sm text-slate-600 dark:text-slate-400">
          Building beautiful and functional web applications with modern
          technologies.
        </p>
      </div>

      <!-- Middle Column -->
      <div>
        <h4 class="font-bold text-slate-900 dark:text-white">Quick Links</h4>
        <nav class="mt-4 space-y-2">
          <a
            href="#about"
            class="block text-sm text-slate-600 hover:text-blue-500 dark:text-slate-400 dark:hover:text-blue-400"
          >
            About
          </a>
          <a
            href="#skills"
            class="block text-sm text-slate-600 hover:text-blue-500 dark:text-slate-400 dark:hover:text-blue-400"
          >
            Skills
          </a>
          <a
            href="#projects"
            class="block text-sm text-slate-600 hover:text-blue-500 dark:text-slate-400 dark:hover:text-blue-400"
          >
            Projects
          </a>
          <a
            href="#work-experience"
            class="block text-sm text-slate-600 hover:text-blue-500 dark:text-slate-400 dark:hover:text-blue-400"
          >
            Work Experience
          </a>
        </nav>
      </div>

      <!-- Right Column -->
      <div>
        <h4 class="font-bold text-slate-900 dark:text-white">Connect</h4>
        <div class="mt-4 flex gap-4">
          <a
            href="https://github.com/seyren10"
            target="_blank"
            class="flex h-10 w-10 items-center justify-center rounded-lg border border-slate-200 text-slate-600 hover:border-blue-500 hover:text-blue-500 dark:border-slate-700 dark:text-slate-400 dark:hover:border-blue-400 dark:hover:text-blue-400"
            aria-label="GitHub"
          >
            <HugeiconsIcon icon={GithubIcon} className="size-5" />
          </a>
          <a
            href="https://www.linkedin.com/in/roy-gagarin-38b790261"
            target="_blank"
            aria-label="LinkedIn"
            class="flex h-10 w-10 items-center justify-center rounded-lg border border-slate-200 text-slate-600 hover:border-blue-500 hover:text-blue-500 dark:border-slate-700 dark:text-slate-400 dark:hover:border-blue-400 dark:hover:text-blue-400"
          >
            <HugeiconsIcon icon={Linkedin02Icon} className="size-5" />
          </a>
          <a
            href="mailto:gagarinroyvictor@gmail.com"
            aria-label="email"
            class="flex h-10 w-10 items-center justify-center rounded-lg border border-slate-200 text-slate-600 hover:border-blue-500 hover:text-blue-500 dark:border-slate-700 dark:text-slate-400 dark:hover:border-blue-400 dark:hover:text-blue-400"
          >
            <HugeiconsIcon icon={Mail01Icon} className="size-5" />
          </a>
        </div>
      </div>
    </div>

    <!-- Bottom Section -->
    <div
      class="mt-12 flex flex-col justify-between border-t border-slate-200 pt-8 text-sm text-slate-600 md:flex-row dark:border-slate-700 dark:text-slate-400"
    >
      <p>© 2026 Roy Victor Gagarin. All rights reserved.</p>
      <p>Crafted with care and modern web technologies</p>
    </div>
  </div>
</footer>
