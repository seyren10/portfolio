---
import { Call02Icon, Email, Location, Phone } from "@hugeicons/core-free-icons"
import { HugeiconsIcon } from "@hugeicons/react"
import { Button } from "@/components/ui/button"
---

<section id="contact" class="scroll-m-20 p-4 md:p-0">
  <div class="container mx-auto max-w-4xl space-y-12 py-16 text-center">
    <h2 class="text-4xl font-bold text-blue-500 md:text-5xl">Get In Touch</h2>

    <ul class="mt-10 grid gap-6 text-left md:grid-cols-3" data-stagger="200">
      <li class="space-y-4 rounded-lg border bg-background p-4 shadow-sm" data-reveal="scale">
        <div class="flex items-center gap-3">
          <div
            class="grid size-10 place-content-center rounded-xl bg-blue-500/30 text-blue-500"
          >
            <HugeiconsIcon icon={Email} />
          </div>
          <div>
            <h3 class="text-xl font-bold">Email</h3>
            <p class="text-slate-600 dark:text-slate-400">
              Get in touch via email
            </p>
          </div>
        </div>
        <a
          href="mailto:gagarinroyvictor@gmail.com"
          class="font-bold text-blue-500 hover:underline"
        >
          gagarinroyvictor@gmail.com
        </a>
      </li>
      <li class="space-y-4 rounded-lg border bg-background p-4 shadow-sm" data-reveal="scale">
        <div class="flex items-center gap-3">
          <div
            class="grid size-10 place-content-center rounded-xl bg-blue-500/30 text-blue-500"
          >
            <HugeiconsIcon icon={Call02Icon} />
          </div>
          <div>
            <h3 class="text-xl font-bold">Phone</h3>
            <p class="text-slate-600 dark:text-slate-400">Call me anytime</p>
          </div>
        </div>
        <a
          href="tel:+639563040025"
          class="font-bold text-blue-500 hover:underline"
        >
          (+63) 956 304 0025
        </a>
      </li>
      <li class="space-y-4 rounded-lg border bg-background p-4 shadow-sm" data-reveal="scale">
        <div class="flex items-center gap-3">
          <div
            class="grid size-10 place-content-center rounded-xl bg-blue-500/30 text-blue-500"
          >
            <HugeiconsIcon icon={Location} />
          </div>
          <div>
            <h3 class="text-xl font-bold">Location</h3>
            <p class="text-slate-600 dark:text-slate-400">
              Based in Tarlac, PH
            </p>
          </div>
        </div>
        <span class="font-bold text-blue-500">
          San Nicolas, Victoria, Tarlac
        </span>
      </li>
    </ul>

    <div
      class="contact-bg relative isolate space-y-4 overflow-hidden rounded-xl bg-background md:p-20 p-6"
      data-reveal="bottom"
      data-delay="600"
    >
      <h3 class="text-3xl font-bold md:text-5xl">
        Ready to build something amazing?
      </h3>
      <p
        class="mx-auto max-w-[65ch] text-base leading-relaxed text-balance text-slate-600 md:text-lg dark:text-slate-200"
      >
        I'm always open to discussing new projects, creative ideas or
        opportunities to be part of your vision.
      </p>
      <div class="flex items-center justify-center gap-4">
        <a href="mailto:gagarinroyvictor@gmail.com">
          <Button client:visible size="lg"> Send me an email </Button>
        </a>
        <a href="/portfolio/Roy_Victor_Gagarin_CV.pdf" download>
          <Button
            client:visible
            size="lg"
            variant="outline"
            className="border-primary text-primary hover:bg-primary/10 hover:text-primary dark:text-primary-foreground"
          >
            Download CV
          </Button>
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .contact-bg::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: -1;
    background-color: var(--background);
    opacity: 0.3;
    background-image:
      repeating-radial-gradient(
        circle at 0 0,
        transparent 0,
        var(--background) 40px
      ),
      repeating-linear-gradient(var(--background), var(--color-blue-500));
  }
</style>
